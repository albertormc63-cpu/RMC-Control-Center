# Base de datos compartida por los CEPs de RMC.
RMC_DB_PATH=/ruta/a/RMC_CEP.sqlite
PORT=3000

# Unica raiz desde la que RMC Control Center puede servir archivos.
RMC_FILE_ROOT=/Volumes/Fullsize

# Nombre que se mostrara al iniciar el servidor.
RMC_LAN_HOST=rmccontrolcenter.local

# Registro local de accesos HTTP.
RMC_ACCESS_LOG_ENABLED=true
RMC_ACCESS_LOG_PATH=logs/access.log

# Polling automatico de fuentes externas.
# Revisa mtime/size del Excel y sincroniza solo cuando detecta cambios.
RMC_SYNC_POLL_ENABLED=true
RMC_SYNC_POLL_INTERVAL_MS=300000
RMC_SYNC_POLL_STABILIZE_MS=10000
